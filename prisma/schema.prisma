// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  user_id           String       @id @default(uuid())
  user_username     String       @unique @db.VarChar(15)
  user_name         String       @db.VarChar(100)
  user_email        String       @unique @db.VarChar(50)
  user_password     String
  user_role         UserRole     @default(USER)
  user_is_verified  Boolean      @default(false)
  user_mfa_methods  MfaMethods[] @default([])
  user_date_created DateTime     @default(now())
  user_date_updated DateTime     @updatedAt
  tasks             Task[]
  categories        Category[]
  totp              Totp?
}

model Totp {
  totp_id           String   @id @default(uuid())
  totp_secret       String   @db.Text // encrypted
  totp_enabled      Boolean  @default(false)
  totp_last_used    DateTime?
  totp_date_created DateTime @default(now())
  totp_date_updated DateTime @updatedAt
  user_id           String   @unique
  user              User     @relation(fields: [user_id], references: [user_id])
}

model Task {
  task_id           String     @id @default(uuid())
  task_title        String     @db.VarChar(30)
  task_description  String?    @db.VarChar(30)
  task_status       TaskStatus @default(UNFINISHED)
  task_date_created DateTime   @default(now())
  task_date_updated DateTime   @updatedAt
  user_id           String
  category_id       String?
  user              User       @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  category          Category?  @relation(fields: [category_id], references: [category_id], onDelete: SetNull)
}

model Category {
  category_id           String   @id @default(uuid())
  category_name         String   @db.VarChar(20)
  category_date_created DateTime @default(now())
  category_date_updated DateTime @updatedAt
  user_id               String?
  user                  User?    @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  task                  Task[]
}

enum UserRole {
  USER
  ADMIN
}

enum TaskStatus {
  FINISHED
  UNFINISHED
}

enum MfaMethods {
  EMAIL_BASED_OTP
  AUTHENTICATOR_APP_TOTP
}
